# Public app origin used for invite links and email CTAs.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project credentials.
NEXT_PUBLIC_SUPABASE_URL=__CHANGE_ME__
NEXT_PUBLIC_SUPABASE_ANON_KEY=__CHANGE_ME__
SUPABASE_SERVICE_ROLE_KEY=__CHANGE_ME__
DATABASE_URL=__CHANGE_ME__

# Transactional email. RESEND_FROM_EMAIL may use Resend's test sender locally.
RESEND_API_KEY=__CHANGE_ME__
RESEND_FROM_EMAIL="Fortexa <onboarding@resend.dev>"

# Sentry. NEXT_PUBLIC_SENTRY_DSN is used by the browser bundle.
SENTRY_DSN=__CHANGE_ME__
NEXT_PUBLIC_SENTRY_DSN=__CHANGE_ME__
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Inngest background jobs and cron functions.
INNGEST_APP_ID=fortexa
INNGEST_EVENT_KEY=__CHANGE_ME__
INNGEST_SIGNING_KEY=__CHANGE_ME__

# DigitalOcean Gradient AI enrichment.
DIGITALOCEAN_GRADIENT_MODEL_ACCESS_KEY=__CHANGE_ME__
DIGITALOCEAN_TOKEN=
DIGITALOCEAN_GRADIENT_MODEL=openai-gpt-oss-20b
DIGITALOCEAN_GRADIENT_BASE_URL=https://inference.do-ai.run/v1
DIGITALOCEAN_GRADIENT_TIMEOUT_MS=30000

# Optional Supabase Storage bucket names.
FORTEXA_REPORTS_BUCKET=fortexa-reports
FORTEXA_SCAN_IMPORTS_BUCKET=fortexa-scan-imports
